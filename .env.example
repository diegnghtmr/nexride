# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── PostgreSQL + PostGIS ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nexride
DB_PASSWORD=nexride_dev
DB_DATABASE=nexride
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Dispatch thresholds (DD-02 §9) ──────────────────────
DISPATCH_CANDIDATE_RADIUS_KM=5
DISPATCH_SAFE_POINT_RADIUS_M=120
DISPATCH_SUGGESTION_THRESHOLD_PCT=0.15
DISPATCH_ORIGINAL_SAFETY_BASELINE=0.30
DISPATCH_WEIGHT_PROXIMITY=0.30
DISPATCH_WEIGHT_ENERGY=0.25
DISPATCH_WEIGHT_SAFETY=0.25
DISPATCH_WEIGHT_CONTINUITY=0.20
DISPATCH_PIPELINE_TIMEOUT_MS=1200
DISPATCH_FALLBACK_MIN_BATTERY_PCT=20
DISPATCH_MAX_ETA_SECONDS=600

# ─── Fleet ───────────────────────────────────────────────
FLEET_MINIMUM_RESERVE_PCT=15
FLEET_TELEMETRY_STALENESS_SEC=60

# ─── Distance provider ───────────────────────────────────
DISTANCE_CACHE_TTL_SEC=60
DISTANCE_PROVIDER_TIMEOUT_MS=800
DISTANCE_PROVIDER_INJECT_TIMEOUT=false

# ─── Test context (NODE_ENV != production) ───────────────
TEST_CONTEXT_GUARD_ENABLED=true
