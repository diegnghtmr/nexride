# NexRide MVP — environment configuration template
# Copy to `.env` and edit the values for your environment.
# DATABASE_URL takes precedence over granular DB_* keys.
# Granular DB_*/REDIS_* keys remain documented as a fallback for tools
# (legacy compose, ad-hoc scripts) that don't accept connection URLs.

# ─── Runtime ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database (canonical) ──────────────────────────────────────────────
DATABASE_URL=postgresql://nexride:nexride_dev@localhost:5432/nexride

# ─── Database (granular fallback — only used if DATABASE_URL is unset) ──
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nexride
DB_PASSWORD=nexride_dev
DB_DATABASE=nexride
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ─── Redis (canonical) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Redis (granular fallback) ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── Dispatch weights (sum must equal 1.0) ─────────────────────────────
DISPATCH_W_PROXIMITY=0.30
DISPATCH_W_ENERGY=0.25
DISPATCH_W_SAFETY=0.25
DISPATCH_W_CONTINUITY=0.20

# ─── Dispatch scoring caps and constants ───────────────────────────────
DISPATCH_SCORING_MAX_DISTANCE_M=5000
DISPATCH_SCORING_MAX_ETA_S=900
DISPATCH_SCORING_MIN_SAFETY=0.0
DISPATCH_SCORING_MAX_SAFETY=1.0
DISPATCH_SCORING_CONTINUITY_BATTERY_WEIGHT=0.7
DISPATCH_SCORING_CONTINUITY_ZONE_WEIGHT=0.3

# ─── Dispatch thresholds ───────────────────────────────────────────────
DISPATCH_CANDIDATE_RADIUS_KM=5
DISPATCH_SAFE_POINT_RADIUS_M=120
DISPATCH_SUGGESTION_THRESHOLD_PCT=0.15
DISPATCH_ORIGINAL_SAFETY_BASELINE=0.30
DISPATCH_PIPELINE_TIMEOUT_MS=1200
DISPATCH_FALLBACK_MIN_BATTERY=20
DISPATCH_MAX_ETA_SECONDS=600

# ─── Fleet ─────────────────────────────────────────────────────────────
FLEET_MINIMUM_RESERVE_PCT=0.15
FLEET_TELEMETRY_STALENESS_SEC=60

# ─── Distance provider ─────────────────────────────────────────────────
DISTANCE_CACHE_TTL_SEC=60
DISTANCE_PROVIDER_TIMEOUT_MS=800
DISTANCE_INJECT_TIMEOUT=false

# ─── Rate limiting / Throttler (NFR-17) ────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
THROTTLER_DISABLED=
THROTTLER_TTL_MS=60000
THROTTLER_LIMIT=100

# ─── Test/integration toggles ──────────────────────────────────────────
TEST_CONTEXT_GUARD_ENABLED=false
