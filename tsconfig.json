{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strict": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "paths": {
      "@common/*": ["src/common/*"],
      "@dispatch/*": ["src/dispatch/*"],
      "@fleet/*": ["src/fleet/*"],
      "@safe-points/*": ["src/safe-points/*"],
      "@trip/*": ["src/trip/*"],
      "@analytics/*": ["src/analytics/*"],
      "@rider/*": ["src/rider/*"]
    }
  }
}
