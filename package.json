{
  "name": "nexride-mvp",
  "version": "0.1.18",
  "description": "NexRide MVP — Dispatch vertical slice backend",
  "author": "NexRide Team",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.unit.config.cjs",
    "test:unit": "jest --config jest.unit.config.cjs",
    "test:integration": "jest --config jest.integration.config.cjs --runInBand --forceExit",
    "test:performance": "k6 run test/performance/rides-request.k6.js",
    "test:cov": "jest --config jest.unit.config.cjs --coverage",
    "arch:check": "depcruise --config .dependency-cruiser.cjs src",
    "arch:check:docker": "docker run --rm -v \"$PWD\":/app -w /app node:20-alpine sh -c 'npm ci --omit=dev && npm run arch:check'",
    "verify:env": "ts-node --transpile-only scripts/verify-env-example.ts",
    "openapi:generate": "ts-node scripts/generate-openapi.ts",
    "audit": "npm audit --audit-level=high --omit=dev",
    "gitleaks": "gitleaks detect --source . --no-banner",
    "migrate": "ts-node -e \"require('./src/migrate').run()\"",
    "ci:local": "bash scripts/ci-local.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@opentelemetry/sdk-node": "0.52.1",
    "@paralleldrive/cuid2": "2.2.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "ioredis": "5.4.1",
    "nestjs-pino": "^4.3.0",
    "pg": "8.12.0",
    "pino": "9.3.2",
    "pino-http": "10.3.0",
    "pino-pretty": "11.2.1",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "^0.3.28"
  },
  "engines": {
    "node": ">=20.0.0 <22.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@testcontainers/postgresql": "10.12.0",
    "@testcontainers/redis": "10.12.0",
    "@types/express": "^5.0.6",
    "@types/jest": "29.5.13",
    "@types/node": "20.16.5",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "dependency-cruiser": "16.4.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "jest": "29.7.0",
    "prettier": "3.3.3",
    "supertest": "7.0.0",
    "testcontainers": "10.12.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "5.5.4"
  }
}
